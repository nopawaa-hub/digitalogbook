# ─────────────────────────────────────────────────────────────
# Firebase project configuration
# Copy this file to `.env.local` and paste your project's keys.
# Get them from: Firebase Console → Project settings → Your apps → SDK setup → Config
#
# All 6 values come in one config snippet from the console — paste them all.
# Requires the Blaze plan (Firebase Storage is used for signature &
# handwriting images; Firestore stores the counter + submissions).
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
